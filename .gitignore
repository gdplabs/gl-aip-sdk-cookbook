.env
.venv
.worktrees/*

# Runtime artifacts
__pycache__/
*.py[cod]
*$py.class

# Scratch directory (keep .gitkeep but ignore contents)
scratch/*
!scratch/.gitkeep

# Generated files
data/workspace/reports/*.md
!data/workspace/reports/.gitkeep

# Cookbook-specific runtime artifacts (examples/filesystem-middleware)
examples/filesystem-middleware/scratch/**
!examples/filesystem-middleware/scratch/.gitkeep
examples/filesystem-middleware/data/workspace/*.md